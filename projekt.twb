      <aliases enabled='yes' />
      <column caption='Win rate' datatype='real' name='[Calculation_21486658198503425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([win_probability]) / COUNT([record_id])' />
      </column>
      <column caption='MVP Rate' datatype='real' name='[Calculation_21486658200317954]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [mvp_award] = &quot;Yes&quot; THEN 1 ELSE 0 END) / COUNT([record_id])' />
      </column>
      <column caption='Date Level' datatype='string' name='[Calculation_21486658203521027]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Month&quot; &#13;&#10;  THEN DATENAME(&apos;month&apos;, DATE([match_date]))&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Quarter&quot; &#13;&#10;  THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;, DATE([match_date])))&#13;&#10;ELSE STR(YEAR(DATE([match_date])))&#13;&#10;END' />
      </column>
      <column caption='Avg reaction per team' datatype='real' name='[Calculation_21486658211069956]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [team_name] : AVG([reaction_time_ms]) }' />
      </column>
      <column caption='Avg Fatigue per team' datatype='real' name='[Calculation_21486658211213317]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [team_name] : AVG([fatigue_index]) }' />
      </column>
