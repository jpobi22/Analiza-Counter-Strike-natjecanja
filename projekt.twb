      <aliases enabled='yes' />
      <column caption='Team Score' datatype='real' name='[Calculation_0782307204648960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([team_finals_won]) + SUM([team_total_mvp_rewards])+AVG([team_rating])+AVG([team_total_kd])' />
      </column>
      <column caption='Kill Efficiency' datatype='real' name='[Calculation_0782307216355329]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([match_total_kills]) / AVG([match_total_deaths])' />
      </column>
      <column caption='Avg assists per match' datatype='real' name='[Calculation_0782307216785410]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([match_total_assists])' />
      </column>
      <column caption='Avg Accuracy per Role' datatype='real' name='[Calculation_0782307217915907]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [player_role] : AVG([player_accuracy_percent]) }' />
      </column>
      <column caption='Date Level' datatype='string' name='[Calculation_37278944375898112]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Month&quot; &#13;&#10;  THEN DATENAME(&apos;month&apos;, DATE([date_full_date]))&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Quarter&quot; &#13;&#10;  THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;, DATE([date_full_date])))&#13;&#10;ELSE STR([date_year])&#13;&#10;END' />
      </column>
      <column caption='Finals Won' datatype='integer' name='[Calculation_37637660057378816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [match_wining_team] = [team_name] AND [match_type] = &quot;Final&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='dim_date' datatype='table' name='[__tableau_internal_object_id__].[dim!date_A11981C963F4432E9C2DF27E974A6A6F]' role='measure' type='quantitative' />
