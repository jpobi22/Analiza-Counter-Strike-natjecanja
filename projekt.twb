    <worksheet name='Team rankings'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Top 50 &lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='DATASET (DATASET)' name='federated.0bzyhoh1m3im9812yuz7b0z7jr3d' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Date Granularity' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Year&quot;'>
              <calculation class='tableau' formula='&quot;Year&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0bzyhoh1m3im9812yuz7b0z7jr3d'>
            <column caption='Date Level' datatype='string' name='[Calculation_21486658203521027]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Month&quot; &#13;&#10;  THEN DATENAME(&apos;month&apos;, DATE([match_date]))&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Quarter&quot; &#13;&#10;  THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;, DATE([match_date])))&#13;&#10;ELSE STR(YEAR(DATE([match_date])))&#13;&#10;END' />
            </column>
            <column caption='Finals Won' datatype='integer' name='[Calculation_28801984272912385]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [match_outcome] = &quot;Win&quot; AND [match_type] = &quot;Final&quot; THEN 1 ELSE 0 END)' />
            </column>
            <column caption='Team MVP Count' datatype='integer' name='[Calculation_28801984276557826]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [mvp_award] = &quot;Yes&quot; THEN 1 ELSE 0 END)' />
            </column>
            <column caption='Team score' datatype='integer' name='[Calculation_28801984276623363]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [match_outcome] = &quot;Win&quot; AND [match_type] = &quot;Final&quot; THEN 1 ELSE 0 END)&#13;&#10;+&#13;&#10;SUM(IF [mvp_award] = &quot;Yes&quot; THEN 1 ELSE 0 END)' />
            </column>
            <column datatype='integer' name='[date_year]' role='dimension' type='quantitative' />
            <column datatype='string' name='[match_date]' role='dimension' type='nominal' />
            <column datatype='string' name='[match_outcome]' role='dimension' type='nominal' />
            <column datatype='string' name='[match_type]' role='dimension' type='nominal' />
            <column datatype='string' name='[mvp_award]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_21486658203521027]' derivation='None' name='[none:Calculation_21486658203521027:nk]' pivot='key' type='nominal' />
            <column-instance column='[date_year]' derivation='None' name='[none:date_year:qk]' pivot='key' type='quantitative' />
            <column-instance column='[match_outcome]' derivation='None' name='[none:match_outcome:nk]' pivot='key' type='nominal' />
            <column-instance column='[team_name]' derivation='None' name='[none:team_name:nk]' pivot='key' type='nominal' />
