              <calculation class='tableau' formula='AVG([match_total_assists])' />
            </column>
            <column caption='Avg Accuracy per Role' datatype='real' name='[Calculation_0782307217915907]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [player_role] : AVG([player_accuracy_percent]) }' />
            </column>
            <column caption='Date Level' datatype='string' name='[Calculation_37278944375898112]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Month&quot; &#13;&#10;  THEN DATENAME(&apos;month&apos;, DATE([date_full_date]))&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Quarter&quot; &#13;&#10;  THEN &quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;, DATE([date_full_date])))&#13;&#10;ELSE STR([date_year])&#13;&#10;END' />
