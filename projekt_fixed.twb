          <datasource-dependencies datasource='federated.0bzc6h80vfb8po1cwr5vz0mv0jjm'>
            <column caption='Finals Won' datatype='integer' name='[Calculation_37637660057378816]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [match_wining_team] = [team_name] AND [match_type] = &quot;Final&quot; THEN 1 ELSE 0 END)' />
            </column>
            <column-instance column='[player_rating]' derivation='Avg' name='[avg:player_rating:qk]' pivot='key' type='quantitative' />
            <column-instance column='[player_country]' derivation='Count' name='[cnt:player_country:qk]' pivot='key' type='quantitative' />
            <column datatype='string' name='[match_type]' role='dimension' type='nominal' />
            <column datatype='string' name='[match_wining_team]' role='dimension' type='nominal' />
            <column-instance column='[player_country]' derivation='None' name='[none:player_country:nk]' pivot='key' type='nominal' />
